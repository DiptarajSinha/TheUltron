# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Template for all required environment variables.
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in your real values in .env.local
#   3. NEVER commit .env.local — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
# The anon key is safe for client-side use (it respects Row Level Security).
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/test/apikeys
# The publishable key (NEXT_PUBLIC_) is safe to expose to the browser.
# The secret key must NEVER be given a NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# ─── App URL ───────────────────────────────────────────────────────────────────
# Local development default. Change to your production domain before deploying.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Email Delivery (Nodemailer / Gmail SMTP) ──────────────────────────────────
# Use a Gmail App Password — NOT your regular account password.
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2FA to be enabled on your Google account.)
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_16_char_app_password

# ─── Robot Pass Public Config ──────────────────────────────────────────────────
# This is a QR scan payload value embedded in ticket QR codes.
# It is intentionally public (NEXT_PUBLIC_) because it is read by both the
# server action and the client-side success page. Do NOT treat it as a secret.
NEXT_PUBLIC_UNLOCK_CODE=UNLOCK-772

# ─── Ticket Signing Secret ─────────────────────────────────────────────────────
# Used server-side ONLY to cryptographically sign and verify Robot Pass tickets.
# Generate a new secret with: openssl rand -hex 32
# CRITICAL: Never prefix this with NEXT_PUBLIC_ — it must stay server-side only.
TICKET_SIGNING_SECRET=your_256bit_hex_secret_here
